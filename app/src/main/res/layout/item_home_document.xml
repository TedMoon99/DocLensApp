<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="document"
            type="com.tedmoon.domain.model.category.Document" />
    </data>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="150dp"
        android:layout_height="120dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="12dp"
        app:cardBackgroundColor="@color/surface"
        app:strokeColor="@color/stroke"
        app:cardCornerRadius="12dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="10dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/image_home_document"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:strokeWidth="0dp"
                app:cardCornerRadius="12dp">
                <ImageView
                    android:layout_width="130dp"
                    android:layout_height="80dp"
                    android:contentDescription="@string/image_description"
                    android:src="@drawable/ic_launcher_background"
                    android:scaleType="centerCrop"/>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/text_title"
                android:text="@{document.title}"
                android:textSize="8sp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/image_home_document"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>


<!--            android:text="@{@string/date_page_info}"-->
            <TextView
                android:id="@+id/text_date"
                android:text='@{@string/date_page_info(document.date, document.pageCnt)}'
                android:textSize="6sp"
                android:textColor="@color/gray"
                app:layout_constraintTop_toBottomOf="@id/text_title"
                app:layout_constraintStart_toStartOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>

</layout>